# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# HubSpot OAuth Configuration
HUBSPOT_CLIENT_ID=your-client-id
HUBSPOT_CLIENT_SECRET=your-client-secret
HUBSPOT_REDIRECT_URI=http://localhost:3001/api/oauth/callback
HUBSPOT_WEBHOOK_SECRET=your-webhook-secret

# HubSpot Personal Access Token (PAT) - Alternative to OAuth
# If set, PAT will be used instead of OAuth for HubSpot API authentication
HUBSPOT_PAT=your-pat-token

# Wix API Configuration
WIX_API_KEY=your-api-key
WIX_ACCOUNT_ID=your-account-id
WIX_SITE_ID=your-site-id
WIX_WEBHOOK_SECRET=your-wix-webhook-secret

# Security Configuration
ENCRYPTION_KEY=your-32-character-encryption-key-minimum

# Redis Configuration (for job queue)
REDIS_URL=redis://localhost:6379

# Server Configuration
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# Data Retention Configuration (GDPR)
RETENTION_SYNC_EVENTS_DAYS=90
RETENTION_FORM_SUBMISSIONS_DAYS=365
RETENTION_DEAD_LETTER_DAYS=30
RETENTION_SYNC_CONFLICTS_DAYS=180

# CORS Configuration (comma-separated list of allowed origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
